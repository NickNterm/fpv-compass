# Copy to .env and fill in real values. Never commit .env.

# Django
DJANGO_SECRET_KEY=generate-a-long-random-string-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=fpv-compass.xyz,www.fpv-compass.xyz

# Postgres
POSTGRES_DB=fpvcompass
POSTGRES_USER=fpvcompass
POSTGRES_PASSWORD=use-a-strong-password

# Django superuser (created on first boot)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=use-a-strong-password
DJANGO_SUPERUSER_EMAIL=you@example.com

# PostHog (optional, frontend analytics)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=
